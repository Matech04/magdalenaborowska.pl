---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import brand from '../content/settings/brand.json';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="uslugi" class="scroll-mt-20 border-t border-line bg-ivory py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-5 lg:px-8">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Oferta</p>
      <h2 class="mt-4 text-balance text-3xl text-ink sm:text-4xl lg:text-5xl">
        Usługi salonu
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted">
        Pełen zakres stylizacji i pielęgnacji. Aktualny cennik oraz dostępne
        terminy znajdziesz w systemie rezerwacji.
      </p>
    </div>

    <ul class="mt-12 grid gap-px overflow-hidden rounded-(--radius-brand) border border-line bg-line sm:grid-cols-2 lg:grid-cols-2">
      {
        services.map((service) => (
          <li class="reveal flex flex-col gap-3 bg-ivory p-7 transition-colors hover:bg-cream/40">
            <span class="flex size-11 items-center justify-center rounded-(--radius-brand) bg-cream text-bronze">
              <Icon name={`lucide:${service.data.icon}`} class="size-5" />
            </span>
            <h3 class="mt-1 font-display text-xl text-ink">{service.data.title}</h3>
            {service.data.category && (
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">
                {service.data.category}
              </span>
            )}
            <p class="text-sm leading-relaxed text-muted">{service.data.description}</p>
          </li>
        ))
      }
    </ul>

    <div class="reveal mt-10">
      <a
        href={brand.bookingUrl}
        class="link-underline inline-flex items-center gap-2 text-sm font-medium tracking-wide text-ink"
      >
        Sprawdź ceny i umów wizytę
        <Icon name="lucide:arrow-right" class="size-4" />
      </a>
    </div>
  </div>
</section>
