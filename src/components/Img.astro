---
/*
 * Zdjęcia lokalne (w repo) optymalizowane przez astro:assets.
 *
 * Keystatic zapisuje w treści ŚCIEŻKĘ (string), np.
 *   /src/assets/images/gallery/realizacja-01.jpg
 * a <Image> potrzebuje zaimportowanego modułu (ImageMetadata) — mostkiem jest
 * import.meta.glob (mapa ścieżka → metadane, rozwiązywana przy buildzie).
 *
 * - ścieżka do src/assets/... → <Image> (AVIF/WebP + srcset),
 * - pełny URL (http/https)    → zwykły <img> (passthrough, gdyby wrócić do CDN).
 *
 * Placeholder (gdy brak src) obsługują komponenty wywołujące.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  /** Szerokości do srcset (tylko dla zdjęć lokalnych). */
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  widths = [400, 600, 800, 1200, 1600],
  sizes = '100vw',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

// Mapa wszystkich lokalnych zdjęć → metadane (eager: rozwiązane przy buildzie).
const localImages = import.meta.glob<ImageMetadata>(
  '/src/assets/images/**/*.{jpeg,jpg,png,webp,avif,gif}',
  { eager: true, import: 'default' },
);

const isRemote = /^https?:\/\//.test(src);
const meta = !isRemote ? localImages[src] : undefined;

// Nie skalujemy w górę ponad rozmiar źródła.
const safeWidths = meta ? widths.filter((w) => w <= meta.width) : widths;
const resolvedWidths = safeWidths.length > 0 ? safeWidths : meta ? [meta.width] : widths;
---

{
  meta ? (
    <Image
      src={meta}
      alt={alt}
      class={className}
      widths={resolvedWidths}
      sizes={sizes}
      loading={loading}
      {...(fetchpriority ? { fetchpriority } : {})}
    />
  ) : (
    <img
      src={src}
      alt={alt}
      class={className}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
    />
  )
}
