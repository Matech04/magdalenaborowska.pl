---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import brand from '../content/settings/brand.json';

const trainings = (await getCollection('trainings')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section
  id="szkolenia"
  class="scroll-mt-20 bg-charcoal py-20 text-cream lg:py-28"
>
  <div class="mx-auto max-w-6xl px-5 lg:px-8">
    <div class="reveal max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">
        Szkolenia
      </p>
      <h2 class="mt-4 text-balance font-display text-3xl text-cream sm:text-4xl lg:text-5xl">
        Ucz się od praktyka
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-cream/70">
        Dzielimy się wiedzą i warsztatem. Szkolenia w kameralnych grupach, z
        naciskiem na praktykę i indywidualne podejście.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        trainings.map((training) => (
          <article class="card-lift reveal flex flex-col rounded-(--radius-brand) border border-cream/15 bg-cream/[0.04] p-8 hover:border-gold/30">
            <div class="flex items-center gap-3">
              <span class="flex size-10 items-center justify-center rounded-(--radius-brand) bg-gold/15 text-gold">
                <Icon name="lucide:graduation-cap" class="size-5" />
              </span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">
                {training.data.level}
              </span>
            </div>
            <h3 class="mt-5 font-display text-2xl text-cream">{training.data.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-cream/70">
              {training.data.description}
            </p>
            {training.data.duration && (
              <p class="mt-5 flex items-center gap-2 text-sm text-cream/60">
                <Icon name="lucide:clock" class="size-4" />
                {training.data.duration}
              </p>
            )}
          </article>
        ))
      }
    </div>

    <div class="reveal mt-10">
      <a href={brand.bookingUrl} class="btn-gold">
        Zapytaj o termin szkolenia
        <Icon name="lucide:arrow-right" class="size-4" />
      </a>
    </div>
  </div>
</section>
