---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const items = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section class="border-t border-line bg-cream/40 py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-5 lg:px-8">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Opinie</p>
      <h2 class="mt-4 text-balance text-3xl text-ink sm:text-4xl lg:text-5xl">
        Co mówią klientki
      </h2>
    </div>

    <ul class="mt-12 grid gap-6 md:grid-cols-3">
      {
        items.map((item) => (
          <li class="card-lift reveal flex flex-col rounded-(--radius-brand) border border-line bg-ivory p-7 hover:border-gold/40">
            <div class="flex gap-1 text-gold" aria-label={`Ocena: ${item.data.rating} na 5`}>
              {Array.from({ length: item.data.rating }).map(() => (
                <Icon name="lucide:star" class="size-4 fill-current" />
              ))}
            </div>
            <blockquote class="mt-5 flex-1 text-lg leading-relaxed text-ink">
              „{item.data.body}”
            </blockquote>
            <cite class="mt-5 text-sm font-medium not-italic text-muted">
              — {item.data.author}
            </cite>
          </li>
        ))
      }
    </ul>
  </div>
</section>
