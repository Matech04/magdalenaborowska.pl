---
import { Icon } from 'astro-icon/components';
import brand from '../content/settings/brand.json';
import contact from '../content/settings/contact.json';
import SalonMap from './SalonMap.astro';
import SocialLinks from './SocialLinks.astro';
---

<section id="kontakt" class="scroll-mt-20 border-t border-line bg-ivory py-20 lg:py-28">
  <div class="mx-auto grid max-w-6xl gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
    <div class="reveal">
      <p class="eyebrow">{contact.eyebrow}</p>
      <h2 class="mt-4 text-balance text-3xl text-ink sm:text-4xl lg:text-5xl">{contact.heading}</h2>
      <p class="mt-5 text-lg leading-relaxed text-muted">{contact.note}</p>

      <a href={brand.bookingUrl} class="btn-primary mt-8">
        Umów wizytę
        <Icon name="lucide:arrow-right" class="size-4" />
      </a>

      <div class="mt-10">
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-bronze">
          Znajdź nas
        </span>
        <SocialLinks size="lg" class="mt-4" />
      </div>
    </div>

    <div class="reveal">
      <dl class="space-y-6">
        <div>
          <dt class="flex items-center gap-2 text-sm font-semibold text-ink">
            <Icon name="lucide:map-pin" class="size-4 shrink-0 text-gold" aria-hidden="true" />
            Adres
          </dt>
          <dd class="mt-1 pl-6 text-muted">{brand.address}</dd>
          {
            brand.mapUrl && (
              <dd class="mt-1 pl-6">
                <a href={brand.mapUrl} class="link-underline text-sm text-bronze">
                  Zobacz na mapie
                </a>
              </dd>
            )
          }
        </div>

        {
          brand.phone && (
            <div>
              <dt class="flex items-center gap-2 text-sm font-semibold text-ink">
                <Icon name="lucide:phone" class="size-4 shrink-0 text-gold" aria-hidden="true" />
                Telefon
              </dt>
              <dd class="mt-1 pl-6 text-muted">
                <a href={`tel:${brand.phone.replace(/\s+/g, '')}`}>{brand.phone}</a>
              </dd>
            </div>
          )
        }

        <div>
          <dt class="flex items-center gap-2 text-sm font-semibold text-ink">
            <Icon name="lucide:clock" class="size-4 shrink-0 text-gold" aria-hidden="true" />
            Godziny otwarcia
          </dt>
          <dd class="mt-1 space-y-1 pl-6 text-muted">
            {
              (brand.hours ?? []).map((h) => (
                <div class="flex justify-between gap-6">
                  <span>{h.day}</span>
                  <span class="text-ink">{h.value}</span>
                </div>
              ))
            }
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="mx-auto mt-14 max-w-6xl px-5 lg:px-8">
    <div class="reveal relative overflow-hidden rounded-(--radius-brand) border border-line shadow-sm">
      <SalonMap />
      <span
        class="pointer-events-none absolute inset-x-0 top-0 z-[500] h-px bg-gradient-to-r from-bronze via-gold to-gold-soft"
      ></span>
    </div>
  </div>
</section>
